{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/registry.schema.json",
  "title": "Spark module registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["modules", "bundles"],
  "properties": {
    "modules": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/module"
      }
    },
    "bundles": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/bundle"
      }
    }
  },
  "$defs": {
    "sha1": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "summary"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "$ref": "#/$defs/sha1"
        },
        "require_signed_commit": {
          "type": "boolean"
        },
        "attestation": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "source", "commit"],
              "properties": {
                "type": {
                  "type": "string",
                  "minLength": 1
                },
                "source": {
                  "type": "string",
                  "minLength": 1
                },
                "commit": {
                  "$ref": "#/$defs/sha1"
                }
              }
            }
          ]
        },
        "attestation_ref": {
          "type": "string",
          "minLength": 1
        },
        "verify_ref": {
          "type": "string",
          "minLength": 1
        },
        "blessed": {
          "type": "boolean",
          "default": false
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "blessed": {
                "const": true
              }
            },
            "required": ["blessed"]
          },
          "then": {
            "required": ["commit", "require_signed_commit"]
          }
        }
      ]
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modules", "summary"],
      "properties": {
        "modules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
