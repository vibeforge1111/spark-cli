+            trace_ref = _event_trace_ref(trace_ref=None, request_id=str(row["request_id"]))
+            if not trace_ref:
+                continue
+            conn.execute(
+                """
+                UPDATE builder_events
+                SET trace_ref = ?
+                WHERE event_id = ?
+                  AND (trace_ref IS NULL OR trim(trace_ref) = '')
+                """,
