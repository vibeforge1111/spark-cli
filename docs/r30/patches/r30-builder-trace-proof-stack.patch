+            "telegram": "joined" if str(record.get("channel_id") or "") == "telegram" else "not_applicable",
+            "builder": "joined",
+            "spawner": "not_applicable",
+            "provider": "not_applicable",
+            "memory": "not_applicable",
+            "voice": "not_applicable",
+        },
+    }
